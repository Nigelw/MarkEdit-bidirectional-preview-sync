{
  "name": "markedit-bidirectional-preview-sync",
  "version": "1.0.0",
  "description": "Best-effort bidirectional preview sync for MarkEdit and MarkEdit-preview.",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "reload": "osascript -e 'quit app \"MarkEdit\"' -e 'delay 1' -e 'launch app \"MarkEdit\"'",
    "uninstall": "rm ~/Library/Containers/app.cyan.markedit/Data/Documents/scripts/$(node -p \"require('./package.json').name\").js"
  },
  "devDependencies": {
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@types/node": "^22.0.0",
    "markedit-api": "https://github.com/MarkEdit-app/MarkEdit-api",
    "markedit-vite": "https://github.com/MarkEdit-app/MarkEdit-vite",
    "typescript": "^5.0.0",
    "vite": "^6.4.3"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
